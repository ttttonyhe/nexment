{
  "name": "nexment",
  "author": "ttttonyhe",
  "version": "0.1.1",
  "description": "A feature-rich serverless comment library for React",
  "repository": "git@github.com:ttttonyhe/nexment.git",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --port 6006",
    "build": "tsx ./scripts/build.ts",
    "lint": "eslint --fix --ext .ts,.tsx src && prettier src --write --log-level silent",
    "test": "jest",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "publish": "npx changeset publish"
  },
  "dependencies": {
    "@neondatabase/neon-js": "^0.2.0-beta.1",
    "@supabase/supabase-js": "^2.98.0",
    "dompurify": "^3.3.1",
    "email-validator": "^2.0.4",
    "github-markdown-css": "^5.9.0",
    "js-md5": "^0.8.3",
    "react-textarea-autosize": "^8.5.9",
    "react-tiny-popover": "^8.1.6",
    "showdown": "^2.1.0",
    "swr": "^2.4.1",
    "timeago.js": "^4.0.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/js-md5": "^0.8.0",
    "@types/qs": "^6.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/showdown": "^2.0.6",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "cypress": "^15.11.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-d.ts": "^1.3.1",
    "esbuild-sass-plugin": "^3.6.0",
    "eslint": "^8",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "packageManager": "pnpm@10.6.2"
}
